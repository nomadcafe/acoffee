# Optional. Without these, pins and emails are stored in memory and reset
# whenever the dev server restarts. Apply supabase/schema.sql in your
# Supabase project, then paste the keys below.
NEXT_PUBLIC_SUPABASE_URL=

# Settings → API → `service_role` key. Server-side only; bypasses RLS.
# Used by src/lib/store.ts for unauthenticated reads.
SUPABASE_SERVICE_ROLE_KEY=

# Settings → API → `anon` (public) key. Safe to ship to the browser.
# Required for Supabase Auth (magic link, OAuth) via @supabase/ssr.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public origin used for canonical URLs, sitemap, and OG metadata.
# Leave blank for local dev (defaults to http://localhost:3000).
NEXT_PUBLIC_SITE_URL=

# Optional. Without these, intent-response and accept emails are
# silently skipped (DB writes still succeed). Sign up at resend.com,
# verify your sending domain, then paste here.
RESEND_API_KEY=
# Must use a verified Resend domain. Example: "acoffee <hello@acoffee.com>".
# Unverified domains return 403 on send.
EMAIL_FROM=

# Optional. GA4 measurement ID (looks like G-XXXXXXXXXX). Without this,
# the GoogleAnalytics component doesn't mount — local dev / preview
# deploys won't pollute production analytics. Get one at
# analytics.google.com → Admin → Data Streams → Web.
NEXT_PUBLIC_GA_ID=
