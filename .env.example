# Optional. Without these, pins and emails are stored in memory and reset
# whenever the dev server restarts. Apply supabase/schema.sql in your
# Supabase project, then paste the keys below.
NEXT_PUBLIC_SUPABASE_URL=

# Settings → API → `service_role` key. Server-side only; bypasses RLS.
# Used by src/lib/store.ts for unauthenticated reads.
SUPABASE_SERVICE_ROLE_KEY=

# Settings → API → `anon` (public) key. Safe to ship to the browser.
# Required for Supabase Auth (magic link, OAuth) via @supabase/ssr.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public origin used for canonical URLs, sitemap, and OG metadata.
# Leave blank for local dev (defaults to http://localhost:3000).
NEXT_PUBLIC_SITE_URL=
