# acoffee env — copy this file to `.env.local` and fill in the blanks.
# Without Supabase configured the app builds, but every auth- or DB-touching
# route returns "not configured". You need a project to actually save cards.

# Supabase project URL — Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=

# Server-side service-role key. Bypasses RLS, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Public anon key — Settings → API → `anon` (public) key. Safe in the
# browser; required by Supabase Auth (magic link / OAuth) via @supabase/ssr.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public origin for canonical URLs, sitemap, and OG metadata.
# Leave blank for local dev — defaults to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# Optional. Without these, the welcome email after onboarding is silently
# skipped (the profile save still succeeds). Sign up at resend.com, verify
# a sending domain, then paste the API key + From address below.
RESEND_API_KEY=

# Must use a verified Resend domain. Example: "acoffee <hello@acoffee.com>".
# Unverified domains return 403 on send.
EMAIL_FROM=

# Optional. GA4 measurement ID (looks like G-XXXXXXXXXX). Without this the
# GoogleAnalytics component never mounts — local dev / preview deploys
# won't pollute production analytics. analytics.google.com → Admin → Data
# Streams → Web.
NEXT_PUBLIC_GA_ID=
