# acoffee env — copy this file to `.env.local` and fill in the blanks.
# Without Supabase configured the app builds, but every auth- or DB-touching
# route returns "not configured". You need a project to actually save cards.

# Supabase project URL — Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=

# Server-side service-role key. Bypasses RLS, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Public anon key — Settings → API → `anon` (public) key. Safe in the
# browser; required by Supabase Auth (magic link / OAuth) via @supabase/ssr.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public origin for canonical URLs, sitemap, and OG metadata.
# Leave blank for local dev — defaults to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# Transactional email (invites, welcome, confirm). Optional — without a
# configured backend these are silently skipped and the DB write still
# succeeds. Two interchangeable backends, picked automatically:
#
#   • SMTP   — set SMTP_HOST (+ port/user/pass). Use any provider, e.g. the
#              same one wired into Supabase's auth emails, so the whole app
#              shares one mailbox + one already-verified sending domain.
#   • Resend — set RESEND_API_KEY. Kept as a drop-in fallback.
#
# Auto-detect prefers SMTP when SMTP_HOST is set, else Resend. Force one
# with EMAIL_PROVIDER below (handy to flip back to Resend if SMTP flakes).
# EMAIL_FROM is required either way; its domain must be verified with
# whichever provider you actually send through.
EMAIL_FROM=

# Optional: "smtp" | "resend". Unset = auto-detect (see above).
EMAIL_PROVIDER=

# SMTP backend. Requires `npm i nodemailer`. Port 465 = implicit TLS;
# 587 / 2525 = STARTTLS. User/pass optional for IP-allowlisted relays.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Resend backend (fallback). Sign up at resend.com, verify a sending
# domain, paste the API key. Used when SMTP_HOST is unset (or
# EMAIL_PROVIDER=resend).
RESEND_API_KEY=

# Optional. GA4 measurement ID (looks like G-XXXXXXXXXX). Without this the
# GoogleAnalytics component never mounts — local dev / preview deploys
# won't pollute production analytics. analytics.google.com → Admin → Data
# Streams → Web.
NEXT_PUBLIC_GA_ID=
